# Optional: enable live FIFA match data from football-data.org
# Get a free key at https://www.football-data.org/client/register
# Without this, the app uses bundled mock World Cup 2026 data.
VITE_FOOTBALL_API_KEY=

# Optional: shared cloud database so everyone plays from their own phone.
# Supabase → Settings → API. ONLY use the browser-safe keys here:
#   - Project URL
#   - the "publishable" key  (sb_publishable_…)  OR the legacy "anon" key
# NEVER put the secret / service_role / JWT secret in this file.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
