{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/football/:path*", "destination": "https://api.football-data.org/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
